# ──────────────────────────────────────────────
# BioClaw Environment Configuration
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# ─── Required ─────────────────────────────────

# Anthropic API key (required for Claude agent inside containers)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ─── WhatsApp ─────────────────────────────────

# WhatsApp uses QR code authentication via Baileys.
# No credentials needed here — run `npm start` and scan the QR code
# with your WhatsApp app. Auth state is persisted in store/auth/.

# ─── Feishu / Lark (optional) ─────────────────
# Create a self-built app at https://open.feishu.cn/
# Enable: Bot capability, im:message, im:message:send_as_bot, im:resource
# Under Events & Callbacks → choose "Long connection" (长连接)
FEISHU_APP_ID=cli_your_app_id
FEISHU_APP_SECRET=your_app_secret
